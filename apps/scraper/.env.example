# apps/scraper — copy to .env on the India box (never commit .env)

# Supabase Postgres connection string (Project Settings → Database → Connection string).
# The scraper connects as the postgres role (bypasses RLS — it's trusted infra).
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# Scraper behaviour
PROP_HEADLESS=0                 # 0 = headful real Chrome (required for anti-bot, D26)
PROP_BROWSER_CHANNEL=chrome     # use the installed Google Chrome
PROP_DATA_DIR=./data            # where the persistent Chrome profile lives

# Telegram alerts (optional; leave blank to skip)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

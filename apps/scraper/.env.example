# apps/scraper — copy to .env on the India box (never commit .env)

# Supabase (service-role key — full DB access; keep secret, server-side only)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scraper behaviour
PROP_HEADLESS=0                 # 0 = headful real Chrome (required for anti-bot, D26)
BROWSER_CHANNEL=chrome          # use the installed Google Chrome
SCRAPE_PORTALS=magicbricks      # comma-separated; only magicbricks for now

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

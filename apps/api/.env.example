# apps/api — copy to .env (never commit .env)

# Supabase Postgres connection string (Project Settings → Database)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# Supabase (for verifying user JWTs + privileged writes)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret      # Project Settings → API → JWT Settings

# CORS — the deployed web origin
WEB_ORIGIN=http://localhost:3000

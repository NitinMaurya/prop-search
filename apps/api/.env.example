# apps/api — copy to .env (never commit .env)

# Supabase Postgres connection string (Project Settings → Database → Connection string →
# URI). The API connects as the postgres role and scopes every user query by user_id.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# Project URL — used to fetch the JWKS that verifies user JWTs (ES256, modern Supabase).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# (Legacy only: set SUPABASE_JWT_SECRET instead if your project still uses HS256.)

# CORS — comma-separated allowed web origins
WEB_ORIGIN=http://localhost:3000

# Optional: server port (default 8000)
PORT=8000

# apps/api — copy to .env (never commit .env)

# Supabase Postgres connection string (Project Settings → Database). The API connects as
# the postgres role and scopes every user query by the authenticated user_id in SQL.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres

# Used to verify the user's Supabase JWT (Project Settings → API → JWT Settings → secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# CORS — comma-separated allowed web origins
WEB_ORIGIN=http://localhost:3000

# Optional: server port (default 8000)
PORT=8000
